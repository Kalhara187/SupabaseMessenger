{
  "expo": {
    "name": "SQLRealtimeMessenger",
    "slug": "sqlrealtimemessenger",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "updates": {
      "enabled": false
    },
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B141A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.sqlrealtime.messenger",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "f93e4a9a-9975-4778-b7cd-91ea9d597b52"
      }
    },
    "plugins": [
      "expo-notifications",
      "expo-image-picker"
    ]
  }
}
